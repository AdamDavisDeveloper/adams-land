---
import '../styles/Global.css';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
const { tabTitle, headerImg } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon/morning.ico" id="dynamic-favicon" />
    <title>{tabTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <div id="Noise"></div>
    <div id="container">
      <div id="headerArea">
        <Header src={headerImg} />
        <Nav />
      </div>
      <slot />
    </div>
    <!--
    <script src="/js/dynamicFavicons.js"></script>
    -->
    <slot name="scripts" />
  </body>
</html>
